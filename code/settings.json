{
    // Editor
    "workbench.editor.showTabs": "multiple",
    "workbench.tree.indent": 16,
    "editor.minimap.enabled": true,
    "editor.smoothScrolling": true,

    // Explorer
    "explorer.compactFolders": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,

    // Editor Fonts
    "editor.fontFamily": "JetBrains Mono, Monocraft, Fira Code",
    "editor.fontLigatures": true,
    "editor.fontSize": 16,
    "editor.lineHeight": 2,

    // Terminal Fonts
    "terminal.integrated.fontFamily": "JetBrains Mono, Monocraft, Fira Code",
    "terminal.integrated.lineHeight": 1.2,
    "terminal.integrated.fontSize": 14,

    // Code Actions
    "editor.lightbulb.enabled": "off",
    "files.trimTrailingWhitespace": true,
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",

    // Theme
    "workbench.colorTheme": "Catppuccin Frappé",
    "workbench.iconTheme": "flow-deep",

    // Extensions
    "dateTime.customFormat": "· dddd, DD/MM/YYYY · HH:mm",
    "dateTime.statusBarAlignment": "right",
    "biome.suggestInstallingGlobally": false,
    "vscode-pets.theme": "winter",
    "vscode-pets.throwBallWithMouse": true,

    // Window
    "window.zoomLevel": 0,
    "window.titleBarStyle": "custom",
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "cursor.composer.usageSummaryDisplay": "always",
    "window.customTitleBarVisibility": "never",

    // git
    "git.confirmSync": false,
    "git.autofetch": true,

    // Utils
    "symbols.hidesExplorerArrows": false,
    "window.commandCenter": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.mouseWheelScrollSensitivity": 2,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "files.exclude": {
      "**/node_modules": true
    },
    "githubPullRequests.fileListLayout": "tree",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "cursor.cpp.disabledLanguages": [
      "plaintext",
      "untitled"
    ],
    "git.enableSmartCommit": true,
    "window.menuBarVisibility": "compact",
    "workbench.navigationControl.enabled": false,
    "workbench.layoutControl.enabled": false,
    "cursor.general.glassShowWarningNotifications": true,
    "window.autoDetectColorScheme": false
  }
